    def test_blocking_acceptance_sequence(self):
        """
        Пошаговый приемочный сценарий по ТЗ.

        Сценарий помогает вручную пройти последовательность проверок:
        1. неверный логин;
        2. повторный неверный логин;
        3. ожидаемая блокировка;
        4. запрет пользовательского запроса к БД;
        5. смена пароля;
        6. повторная авторизация.
        """
        self.print_test_title("ПРИЕМОЧНЫЙ СЦЕНАРИЙ БЛОКИРОВКИ ПО ТЗ")
        phone = self.input_with_default("Введите номер телефона тестового пользователя", "9991234567")
        wrong_password = self.input_with_default("Введите неверный пароль", "wrong_password")
        new_password = self.input_with_default("Введите новый пароль для разблокировки", "new_secure_password")
        user_id = self.input_with_default("Введите ID пользователя", "1")

        print("\nШаг 1. Первая неуспешная авторизация")
        self.send_request("/user/login", {"phone": phone, "password": wrong_password})

        print("\nШаг 2. Вторая неуспешная авторизация")
        self.send_request("/user/login", {"phone": phone, "password": wrong_password})

        print("\nШаг 3. Проверка возможной блокировки")
        self.send_request("/user/login", {"phone": phone, "password": wrong_password})

        print("\nШаг 4. Проверка запрета /ticket/list")
        self.send_request("/ticket/list", {"user_id": user_id})

        print("\nШаг 5. Разрешенная смена пароля /user/update")
        self.send_request("/user/update", {"user_id": user_id, "email": "user@example.com", "password": new_password})

        print("\nШаг 6. Повторная авторизация с новым паролем")
        self.send_request("/user/login", {"phone": phone, "password": new_password})
        self.wait_for_key()

    def show_menu(self):
        """
        Отображение главного меню тестера.

        Требования интерфейса:
        - все пункты меню нумеруются;
        - 0 всегда означает выход;
        - последними пунктами всегда размещаются:
          xx. Изменить настройки подключения
          0. Выход
        """
        menu_items = [
            ("Проверка доступности сервера (/health)", self.test_server_health),
            ("Авторизация пользователя (/user/login)", self.test_login),
            ("Поиск пользователя (/user/by-phone)", self.test_user_by_phone),
            ("Изменение данных пользователя (/user/update)", self.test_user_update),
            ("Изменение согласия на рассылку (/user/mailing)", self.test_user_mailing),
            ("Список залоговых билетов (/ticket/list)", self.test_ticket_list),
            ("Запись оплаты (/payment/set)", self.test_payment_set),
            ("Загрузка документа (/document/load)", self.test_document_load),
            ("Подписание документа (/document/signed)", self.test_document_signed),
            ("Список документов (/document/list)", self.test_document_list),
            ("Расчет распределения платежа (/payment/calculate-distribution)", self.test_payment_calculate_distribution),
            ("Неверные учетные данные (/user/login)", self.test_login_invalid_credentials),
            ("Ожидаемая блокировка пользователя (/user/login)", self.test_login_blocked_expected),
            ("Запрет /user/update без password при блокировке", self.test_blocked_user_update_without_password),
            ("Смена пароля при блокировке (/user/update)", self.test_blocked_user_update_with_password),
            ("Запрет /ticket/list для заблокированного пользователя", self.test_blocked_ticket_list),
            ("Запрет /document/list для заблокированного пользователя", self.test_blocked_document_list),
            ("Запрет /document/signed для заблокированного пользователя", self.test_blocked_document_signed),
            ("Запрет /document/load для заблокированного пользователя", self.test_blocked_document_load),
            ("Диагностика логирования (/health/logging)", self.test_health_logging),
            ("Приемочный сценарий блокировки по ТЗ", self.test_blocking_acceptance_sequence),
        ]

        while True:
            self.clear_screen()
            print("=" * 80)
            print("ТЕСТЕР БЕЗОПАСНОГО ОБМЕНА ДАННЫМИ")
            print("=" * 80)
            print(f"Сервер: {self.SERVER_URL}")
            print(f"Режим вывода: {'краткий' if self.output_mode == 0 else 'полный'}")
            print("-" * 80)
            for index, (title, _) in enumerate(menu_items, start=1):
                print(f"{index}. {title}")
            print(f"{len(menu_items) + 1}. Изменить настройки подключения")
            print("0. Выход")
            print("-" * 80)

            choice = self.input_with_default("Выберите пункт меню", "0")
            if choice == '0':
                break
            try:
                numeric_choice = int(choice)
            except ValueError:
                print("Ошибка: требуется ввести номер пункта меню.")
                self.wait_for_key()
                continue

            if 1 <= numeric_choice <= len(menu_items):
                menu_items[numeric_choice - 1][1]()
            elif numeric_choice == len(menu_items) + 1:
                self.configure_connection_interactive()
            else:
                print("Ошибка: выбран неизвестный пункт меню.")
                self.wait_for_key()


def parse_arguments():
    """Разбор аргументов командной строки."""
    parser = argparse.ArgumentParser(description="Тестер API безопасного обмена данными")
    parser.add_argument('config', nargs='?', default=None, help='Необязательный путь к JSON-файлу конфигурации сервера')
    return parser.parse_args()


def main():
    """Точка входа: создание тестера, выбор режима и запуск меню."""
    args = parse_arguments()
    tester = SecureDataExchangeTester(config_path=args.config)
    tester.output_mode = tester.ask_output_mode()
    tester.show_menu()


if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print("\nРабота тестера прервана пользователем.")
