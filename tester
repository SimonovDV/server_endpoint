#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import sys
import json
import base64
import time
import shutil
import tempfile
import atexit
import argparse
from datetime import datetime

import requests
from cryptography.hazmat.primitives import serialization
from cryptography.hazmat.primitives.asymmetric import padding, rsa


class SecureDataExchangeTester:
    """
    Основной класс тестировщика API безопасного обмена данными.

    Тестер предназначен для интерактивной проверки endpoint'ов сервера,
    сценариев авторизации, загрузки документов, платежных операций,
    а также сценариев механизма блокировки пользователей в соответствии с ТЗ.

    Принципы интерфейса:
    - все меню числовые;
    - 0 всегда означает возврат или выход;
    - логические ответы вводятся только как 0 или 1;
    - во всех запросах предусмотрены значения по умолчанию;
    - режим вывода выбирается один раз при запуске.
    """

    def __init__(self, config_path=None):
        """Инициализация тестера и загрузка настроек подключения."""
        self.default_server_ip = "192.168.0.19"
        self.default_server_port = 8000
        self.default_scheme = "http"
        self.default_token = "1234"
        self.default_timeout = 30

        self.server_ip = self.default_server_ip
        self.server_port = self.default_server_port
        self.server_scheme = self.default_scheme
        self.TOKEN = self.default_token
        self.request_timeout = self.default_timeout
        self.output_mode = 0
        self.config_path = config_path

        self.script_dir = os.path.dirname(os.path.abspath(__file__))
        self.base_dir = os.path.dirname(sys.executable) if getattr(sys, 'frozen', False) else self.script_dir
        self.keys_dir = os.path.join(self.base_dir, "keys")
        self.files_dir = os.path.join(self.base_dir, "files")
        self.temp_keys_dir = None

        os.makedirs(self.keys_dir, exist_ok=True)
        os.makedirs(self.files_dir, exist_ok=True)

        self.load_settings_from_json(config_path)
        self.rebuild_server_url()
        self.setup_keys()
        atexit.register(self.cleanup_temp_keys)

    def setup_keys(self):
        """Настройка временной директории ключей и подготовка публичного ключа сервера."""
        self.cleanup_old_temp_keys()
        self.temp_keys_dir = tempfile.mkdtemp(prefix="api_tester_keys_")
        self.ensure_public_key()
        self.copy_keys_to_temp()
        self.keys_dir = self.temp_keys_dir

    def cleanup_old_temp_keys(self):
        """Удаление старых временных каталогов с ключами тестера."""
        temp_dir = tempfile.gettempdir()
        for item in os.listdir(temp_dir):
            item_path = os.path.join(temp_dir, item)
            if os.path.isdir(item_path) and item.startswith("api_tester_keys_"):
                try:
                    shutil.rmtree(item_path)
                except Exception:
                    pass

    def copy_keys_to_temp(self):
        """Копирование PEM-файлов во временную директорию тестера."""
        source_keys_dir = os.path.join(self.base_dir, "keys")
        if not os.path.exists(source_keys_dir):
            return False
        copied = 0
        for file_name in os.listdir(source_keys_dir):
            if file_name.endswith('.pem'):
                try:
                    shutil.copy2(os.path.join(source_keys_dir, file_name), os.path.join(self.temp_keys_dir, file_name))
                    copied += 1
                except Exception:
                    pass
        return copied > 0

    def ensure_public_key(self):
        """Создание тестового публичного ключа сервера при его отсутствии."""
        public_key_path = os.path.join(self.base_dir, "keys", "public_server.pem")
        if os.path.exists(public_key_path):
            return
        os.makedirs(os.path.dirname(public_key_path), exist_ok=True)
        private_key = rsa.generate_private_key(public_exponent=65537, key_size=2048)
        public_key = private_key.public_key()
        with open(public_key_path, 'wb') as f:
            f.write(public_key.public_bytes(
                encoding=serialization.Encoding.PEM,
                format=serialization.PublicFormat.SubjectPublicKeyInfo,
            ))

    def cleanup_temp_keys(self):
        """Очистка временной директории ключей при завершении работы тестера."""
        if self.temp_keys_dir and os.path.exists(self.temp_keys_dir):
            try:
                shutil.rmtree(self.temp_keys_dir)
            except Exception:
                pass

    def rebuild_server_url(self):
        """Пересборка базового URL сервера по текущим параметрам подключения."""
        self.SERVER_URL = f"{self.server_scheme}://{self.server_ip}:{self.server_port}"

    def load_settings_from_json(self, config_path):
        """Загрузка настроек подключения из JSON-файла сервера, если он задан."""
        if not config_path or not os.path.exists(config_path):
            return
        try:
            with open(config_path, 'r', encoding='utf-8') as f:
                data = json.load(f)
            self.server_ip = str(data.get('server_ip') or data.get('ip') or data.get('host') or self.server_ip)
            self.server_port = int(data.get('server_port') or data.get('port') or self.server_port)
            self.server_scheme = str(data.get('scheme') or data.get('protocol') or self.server_scheme)
            self.TOKEN = str(data.get('token') or self.TOKEN)
            self.request_timeout = int(data.get('request_timeout') or data.get('timeout') or self.request_timeout)
        except Exception as e:
            print(f"Предупреждение: не удалось загрузить настройки из JSON: {e}")

    def clear_screen(self):
        """Очистка экрана консоли."""
        os.system('cls' if os.name == 'nt' else 'clear')

    def wait_for_key(self, message="Нажмите Enter для продолжения..."):
        """Ожидание подтверждения пользователя."""
        input(f"\n{message}")

    def get_current_date(self):
