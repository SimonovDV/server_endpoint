def parse_arguments():
    """
    Разбор аргументов командной строки.

    Returns:
        argparse.Namespace: Объект с аргументами запуска.
    """
    parser = argparse.ArgumentParser(description="Тестер API безопасного обмена данными")
    parser.add_argument(
        'config',
        nargs='?',
        default=None,
        help='Необязательный путь к JSON-файлу конфигурации сервера'
    )
    return parser.parse_args()


def main():
    """
    Точка входа в программу.

    Создает экземпляр тестера, загружает настройки из JSON-файла при наличии,
    один раз запрашивает режим вывода и запускает главное меню.
    """
    args = parse_arguments()
    tester = SecureDataExchangeTester(config_path=args.config)
    tester.output_mode = tester.ask_output_mode()
    tester.show_menu()


if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print("\nРабота тестера прервана пользователем.")
