    def test_payment_set(self):
        """Тест endpoint /payment/set."""
        self.print_test_title("ЗАПИСЬ ОПЛАТЫ")
        transaction_id = self.input_with_default("Введите ID транзакции", "1001")
        user_id = self.input_with_default("Введите ID пользователя", "1")
        payment_date = self.input_with_default("Введите дату платежа ISO", "2026-07-11T12:00:00")
        items = []

        while True:
            ticket_id = self.input_with_default("ID залогового билета (ticket_id)", "1")
            amount = self.input_with_default("Сумма платежа", "100.00")
            items.append({"ticket_id": ticket_id, "amount": amount})
            if self.input_bool01("Добавить еще одну запись? (0 - нет, 1 - да)", 0) == 0:
