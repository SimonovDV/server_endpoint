#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import sys
import json
import base64
import time
import shutil
import tempfile
import atexit
import argparse
from datetime import datetime

import requests
from cryptography.hazmat.primitives import serialization
from cryptography.hazmat.primitives.asymmetric import padding, rsa


class SecureDataExchangeTester:
    """
    Основной класс тестировщика API для безопасного обмена данными.

    Класс предоставляет функционал для тестирования серверных endpoint'ов,
    управления параметрами подключения, работы с ключами шифрования,
    отправки запросов и анализа ответов сервера.

    Поддерживаются два режима вывода:
    - 0: краткий режим
    - 1: полный режим

    Режим вывода выбирается пользователем один раз при запуске программы
    и далее используется всеми тестами.
    """

    def __init__(self, config_path=None):
        """
        Инициализация тестировщика API.

        Args:
            config_path (str | None): Необязательный путь к JSON-файлу настроек.
                Если файл задан, тестер пытается прочитать из него параметры
                подключения к серверу и поддерживаемые служебные настройки.
        """
        self.default_server_ip = "192.168.0.19"
        self.default_server_port = 8000
        self.default_scheme = "http"
        self.default_token = "1234"
        self.default_timeout = 30

        self.server_ip = self.default_server_ip
        self.server_port = self.default_server_port
        self.server_scheme = self.default_scheme
        self.TOKEN = self.default_token
        self.request_timeout = self.default_timeout
        self.output_mode = 0
        self.config_path = config_path

        self.script_dir = os.path.dirname(os.path.abspath(__file__))
        if getattr(sys, 'frozen', False):
            self.base_dir = os.path.dirname(sys.executable)
            self.is_exe = True
        else:
            self.base_dir = self.script_dir
            self.is_exe = False

        self.keys_dir = os.path.join(self.base_dir, "keys")
        self.files_dir = os.path.join(self.base_dir, "files")
        self.temp_keys_dir = None

        os.makedirs(self.keys_dir, exist_ok=True)
        os.makedirs(self.files_dir, exist_ok=True)

        self.load_settings_from_json(config_path)
        self.rebuild_server_url()
        self.setup_keys()
        atexit.register(self.cleanup_temp_keys)

    def setup_keys(self):
        """
        Настройка системы ключей безопасности.

        Метод очищает старые временные ключи, создает новую временную папку,
        обеспечивает наличие публичного ключа сервера и копирует PEM-файлы
        во временную директорию для дальнейшей работы тестера.
        """
        print("Настройка ключей безопасности...")
        self.cleanup_old_temp_keys()
        self.temp_keys_dir = tempfile.mkdtemp(prefix="api_tester_keys_")
        print(f"Создана временная папка для ключей: {self.temp_keys_dir}")
        self.ensure_public_key()
        self.copy_keys_to_temp()
        self.keys_dir = self.temp_keys_dir
        print("Ключи безопасности настроены успешно!")

    def cleanup_old_temp_keys(self):
        """
        Очистка старых временных директорий с ключами.

        Метод удаляет все временные каталоги, начинающиеся с префикса
        api_tester_keys_, чтобы не накапливать устаревшие ключи в системе.
        """
        temp_dir = tempfile.gettempdir()
        for item in os.listdir(temp_dir):
            item_path = os.path.join(temp_dir, item)
            if os.path.isdir(item_path) and item.startswith("api_tester_keys_"):
                try:
                    shutil.rmtree(item_path)
                except Exception as e:
                    print(f"Ошибка при удалении временной папки {item}: {e}")

    def copy_keys_to_temp(self):
        """
        Копирование PEM-ключей из основной директории во временную.

        Returns:
            bool: True если копирование выполнено успешно, иначе False.
        """
        source_keys_dir = os.path.join(self.base_dir, "keys")
        if not os.path.exists(source_keys_dir):
            print(f"Ошибка: Исходная папка ключей не найдена: {source_keys_dir}")
            return False

        copied_files = []
        for file_name in os.listdir(source_keys_dir):
            if file_name.endswith('.pem'):
                source_path = os.path.join(source_keys_dir, file_name)
                dest_path = os.path.join(self.temp_keys_dir, file_name)
                try:
                    shutil.copy2(source_path, dest_path)
                    copied_files.append(file_name)
                except Exception as e:
                    print(f"Ошибка при копировании {file_name}: {e}")

        if not copied_files:
            print("Предупреждение: PEM-ключи для копирования не найдены")
            return False

        print(f"Скопировано ключей: {len(copied_files)}")
        return True

    def ensure_public_key(self):
        """
        Обеспечение наличия публичного ключа сервера.

        Если файл public_server.pem отсутствует, создается тестовый ключ,
        позволяющий запускать тестер в демонстрационном режиме.
        """
        public_key_path = os.path.join(self.base_dir, "keys", "public_server.pem")
        if os.path.exists(public_key_path):
            return

        print("Создание тестового публичного ключа...")
        os.makedirs(os.path.dirname(public_key_path), exist_ok=True)
        private_key = rsa.generate_private_key(public_exponent=65537, key_size=2048)
        public_key = private_key.public_key()
        with open(public_key_path, 'wb') as f:
            f.write(public_key.public_bytes(
                encoding=serialization.Encoding.PEM,
                format=serialization.PublicFormat.SubjectPublicKeyInfo,
            ))
        print("Тестовый публичный ключ создан.")

    def cleanup_temp_keys(self):
        """
        Очистка временной директории с ключами при завершении программы.
        """
        if self.temp_keys_dir and os.path.exists(self.temp_keys_dir):
            try:
                shutil.rmtree(self.temp_keys_dir)
            except Exception as e:
                print(f"Ошибка при удалении временной папки ключей: {e}")

    def rebuild_server_url(self):
        """
        Пересборка базового URL сервера по текущим настройкам подключения.
        """
        self.SERVER_URL = f"{self.server_scheme}://{self.server_ip}:{self.server_port}"

    def load_settings_from_json(self, config_path):
        """
        Загрузка настроек тестера из JSON-файла.

        Поддерживаемые поля JSON:
        - host, ip, server_ip
        - port, server_port
        - scheme, protocol
        - token
        - request_timeout, timeout

        Args:
            config_path (str | None): Путь к JSON-файлу конфигурации.
        """
        if not config_path:
            return
        if not os.path.exists(config_path):
            print(f"Предупреждение: Файл настроек не найден: {config_path}")
            return

        try:
            with open(config_path, 'r', encoding='utf-8') as f:
                data = json.load(f)
            self.server_ip = str(data.get('server_ip') or data.get('ip') or data.get('host') or self.server_ip)
            self.server_port = int(data.get('server_port') or data.get('port') or self.server_port)
            self.server_scheme = str(data.get('scheme') or data.get('protocol') or self.server_scheme)
            self.TOKEN = str(data.get('token') or self.TOKEN)
            self.request_timeout = int(data.get('request_timeout') or data.get('timeout') or self.request_timeout)
            print(f"Настройки загружены из JSON: {config_path}")
        except Exception as e:
            print(f"Предупреждение: Не удалось загрузить настройки из JSON: {e}")

    def clear_screen(self):
        """Очистка экрана консоли."""
        os.system('cls' if os.name == 'nt' else 'clear')

    def wait_for_key(self, message="Нажмите Enter для продолжения..."):
        """
        Ожидание подтверждения пользователя.

        Args:
            message (str): Текст приглашения к продолжению.
        """
        input(f"\n{message}")

    def get_current_date(self):
        """
        Получение текущей даты в формате DD.MM.YYYY.

        Returns:
            str: Текущая дата.
        """
        return datetime.now().strftime("%d.%m.%Y")

    def input_with_default(self, prompt, default_value):
        """
        Ввод значения с подстановкой значения по умолчанию.

        Args:
            prompt (str): Приглашение к вводу.
            default_value (str): Значение по умолчанию.

        Returns:
            str: Введенное пользователем значение или default_value.
        """
        user_input = input(f"{prompt} [по умолчанию: {default_value}]: ").strip()
        return user_input if user_input else default_value

    def input_int_with_default(self, prompt, default_value):
        """
        Ввод целого числа с отображением значения по умолчанию.

        Args:
            prompt (str): Текст приглашения.
            default_value (int): Значение по умолчанию.

        Returns:
            int: Введенное число или значение по умолчанию.
        """
        while True:
            value = self.input_with_default(prompt, str(default_value))
            try:
                return int(value)
            except ValueError:
                print("Ошибка: требуется ввести целое число.")

    def input_bool01(self, prompt, default_value=0):
        """
        Ввод логического значения в формате 0/1.

        Args:
            prompt (str): Приглашение к вводу.
            default_value (int): Значение по умолчанию, 0 или 1.

        Returns:
            int: 0 - нет, 1 - да.
        """
        while True:
            value = self.input_with_default(prompt, str(default_value))
            if value in ('0', '1'):
                return int(value)
            print("Ошибка: допустимы только 0 или 1.")

    def validate_date(self, date_str):
        """
        Проверка корректности даты в формате DD.MM.YYYY.

        Args:
            date_str (str): Проверяемая дата.

        Returns:
            bool: True если дата корректна, иначе False.
        """
        try:
            day, month, year = map(int, date_str.split('.'))
            datetime(year, month, day)
            return True
        except Exception:
            return False

    def input_date(self, prompt):
        """
        Ввод даты с текущей датой в качестве значения по умолчанию.

        Args:
            prompt (str): Текст приглашения.

        Returns:
            str: Корректная дата в формате DD.MM.YYYY.
        """
        current_date = self.get_current_date()
        while True:
            date_input = self.input_with_default(prompt, current_date)
            if self.validate_date(date_input):
                return date_input
            print("Неверный формат даты. Используйте DD.MM.YYYY")

    def print_current_settings(self):
        """
        Вывод текущих настроек подключения тестера.
        """
        print("\nТекущие настройки:")
        print("-" * 60)
        print(f"Схема: {self.server_scheme}")
        print(f"IP адрес: {self.server_ip}")
        print(f"Порт: {self.server_port}")
        print(f"Базовый URL: {self.SERVER_URL}")
        print(f"Токен: {self.TOKEN}")
        print(f"Таймаут: {self.request_timeout} сек.")
        print(f"Режим вывода: {'краткий' if self.output_mode == 0 else 'полный'}")
        print("-" * 60)

    def configure_connection_interactive(self):
        """
        Интерактивное изменение параметров подключения.

        Метод позволяет пользователю по отдельности задать схему, IP-адрес,
        порт сервера, токен и таймаут запросов без перезапуска тестера.
        """
        self.clear_screen()
        print("=" * 80)
        print("НАСТРОЙКА ПОДКЛЮЧЕНИЯ")
        print("=" * 80)
        self.print_current_settings()

        self.server_scheme = self.input_with_default("Введите схему подключения (http/https)", self.server_scheme)
        self.server_ip = self.input_with_default("Введите IP адрес сервера", self.server_ip)
        self.server_port = self.input_int_with_default("Введите порт сервера", self.server_port)
        self.TOKEN = self.input_with_default("Введите токен", self.TOKEN)
        self.request_timeout = self.input_int_with_default("Введите таймаут запроса в секундах", self.request_timeout)
        self.rebuild_server_url()

        print("\nНастройки обновлены.")
        self.print_current_settings()
        self.wait_for_key()

    def generate_signature(self):
        """
        Генерация цифровой подписи для аутентификации запросов.

        Returns:
            str | None: Base64-подпись или None в случае ошибки.
        """
        try:
            public_key_path = os.path.join(self.keys_dir, "public_server.pem")
            if not os.path.exists(public_key_path):
                print("Ошибка: Файл публичного ключа не найден")
                return None

            with open(public_key_path, 'rb') as f:
                server_public_key = serialization.load_pem_public_key(f.read())

            current_time = int(time.time())
            expiry_time = current_time + 300
            signature_data = f'{self.TOKEN}.{expiry_time}'
            encrypted = server_public_key.encrypt(signature_data.encode('utf-8'), padding.PKCS1v15())
            return base64.b64encode(encrypted).decode('utf-8')
        except Exception as e:
            print(f"Ошибка генерации подписи: {e}")
            return None

    def print_request_info(self, url, headers, data):
        """
        Вывод информации о запросе в зависимости от выбранного режима.

        Args:
            url (str): URL запроса.
            headers (dict): HTTP-заголовки.
            data (dict): JSON-тело запроса.
        """
        if self.output_mode == 0:
            return

        print("\n" + "=" * 80)
        print("ЗАПРОС")
        print("=" * 80)
        print(f"URL: {url}")
        print("\nЗаголовки:")
        for key, value in headers.items():
            if key == 'Signature' and len(value) > 100:
                print(f"  {key}: {value[:50]}...{value[-50:]}")
            else:
                print(f"  {key}: {value}")

        print("\nТело запроса:")
        print("-" * 40)
        if data:
            try:
                json_str = json.dumps(data, ensure_ascii=False, indent=2)
                if 'data' in data and isinstance(data['data'], str) and len(data['data']) > 500:
                    truncated_data = data.copy()
                    truncated_data['data'] = f"[BASE64_DATA: {len(data['data'])} символов]"
                    json_str = json.dumps(truncated_data, ensure_ascii=False, indent=2)
                print(json_str)
            except Exception:
                print(json.dumps(data, ensure_ascii=False))
        else:
            print("{}")
        print("=" * 80)

    def print_response_info(self, response):
        """
        Вывод ответа сервера в кратком или полном формате.

        Args:
            response: Объект ответа requests.Response.
        """
        print("\n" + "=" * 80)
        print("ОТВЕТ СЕРВЕРА")
        print("=" * 80)
        print(f"Статус код: {response.status_code}")

        if self.output_mode == 1:
            print("Заголовки ответа:")
            for key, value in response.headers.items():
                print(f"  {key}: {value}")

        print("\nТело ответа:")
        print("-" * 40)
        try:
            response_json = response.json()
            print(json.dumps(response_json, ensure_ascii=False, indent=2))
        except Exception:
            print(response.text[:1000])
            if len(response.text) > 1000:
                print(f"... [еще {len(response.text) - 1000} символов]")
        print("=" * 80)

    def send_request(self, endpoint, data):
        """
        Отправка HTTP POST-запроса на сервер.

        Args:
            endpoint (str): Endpoint API.
            data (dict): JSON-данные запроса.

        Returns:
            dict | None: Ответ сервера в JSON либо None при ошибке.
        """
        signature = self.generate_signature()
        if not signature:
            return None

        headers = {
            "Content-Type": "application/json",
            "Token": f"Bearer {self.TOKEN}",
            "Signature": signature,
        }
        url = f"{self.SERVER_URL}{endpoint}"
        self.print_request_info(url, headers, data)

        try:
            print("\nОтправка запроса...")
            response = requests.post(url, headers=headers, json=data, timeout=self.request_timeout)
            self.print_response_info(response)
            try:
                return response.json()
            except Exception:
                return {"status_code": response.status_code, "text": response.text}
        except requests.exceptions.RequestException as e:
            print("\n" + "!" * 80)
            print("ОШИБКА ПРИ ВЫПОЛНЕНИИ ЗАПРОСА")
            print("!" * 80)
            print(f"Тип ошибки: {type(e).__name__}")
            print(f"Описание: {e}")
            if hasattr(e, 'response') and e.response is not None:
                print(f"Статус код: {e.response.status_code}")
                print(f"Текст ответа: {e.response.text[:500]}")
            print("!" * 80)
            return None

    def ask_output_mode(self):
        """
        Запрос режима вывода информации у пользователя.

        Returns:
            int: 0 для краткого режима, 1 для полного.
        """
        print("\nВыберите режим вывода информации:")
        print("0. Краткий")
        print("1. Полный")
        while True:
            choice = input("\nВыберите режим (0 или 1) [по умолчанию: 0]: ").strip() or "0"
            if choice in ('0', '1'):
                return int(choice)
            print("Ошибка: допустимы только значения 0 или 1.")

