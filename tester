    def test_document_load(self):
        """
        Тест endpoint /document/load.

        Для упрощения теста пользователь вводит путь к локальному файлу,
        который кодируется в base64 и отправляется в составе JSON.
        """
        self.print_test_title("ЗАГРУЗКА ДОКУМЕНТА")
        file_path = self.input_with_default("Введите путь к файлу", os.path.join(self.files_dir, "test.pdf"))
        user_id = self.input_with_default("Введите ID пользователя", "1")
        description = self.input_with_default("Введите описание документа", "Тестовый документ")
        doc_type = self.input_with_default("Введите тип документа", "pdf")

        if not os.path.exists(file_path):
            print(f"Ошибка: файл не найден: {file_path}")
            self.wait_for_key()
            return

        with open(file_path, 'rb') as f:
            encoded_data = base64.b64encode(f.read()).decode('utf-8')

        data = {
            "user_id": user_id,
            "description": description,
            "type": doc_type,
            "name": os.path.basename(file_path),
            "data": encoded_data,
        }
        self.send_request("/document/load", data)
        self.wait_for_key()

